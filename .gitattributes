# Default: normalize to LF in the repo
* text=auto eol=lf

# Explicitly LF for code and text files
*.js   text eol=lf
*.ts   text eol=lf
*.py   text eol=lf
*.sh   text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.md   text eol=lf
*.css  text eol=lf
*.html text eol=lf

# Windows-specific scripts (the one exception)
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf

# Truly binary — never touch these
*.png  binary
*.jpg  binary
*.gif  binary
*.ico  binary
*.zip  binary
*.pdf  binary
*.exe  binary
